<PreferenceScreen
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:settings="http://schemas.android.com/apk/res/com.android.settings"
    android:title="@string/cutout_progress_title">

    <lineageos.preference.SecureSettingMainSwitchPreference
        android:key="cutout_progress_enabled"
        android:title="@string/cutout_progress_enabled_title"
        android:defaultValue="false" />

    <com.matrixx.settings.preferences.SecureSettingListPreference
        android:key="cutout_progress_ring_color_mode"
        android:title="@string/cutout_progress_ring_color_mode_title"
        android:summary="%s"
        android:entries="@array/cutout_progress_ring_color_mode_entries"
        android:entryValues="@array/cutout_progress_ring_color_mode_values"
        android:defaultValue="0" />

    <Preference
        android:key="cutout_progress_ring_color"
        android:title="@string/cutout_progress_ring_color_title"
        android:summary="#2196F3"
        android:persistent="false"
        android:dependency="cutout_progress_enabled" />

    <Preference
        android:key="cutout_progress_error_color"
        android:title="@string/cutout_progress_error_color_title"
        android:summary="#F44336"
        android:persistent="false" />

    <Preference
        android:key="cutout_progress_finish_flash_color"
        android:title="@string/cutout_progress_finish_flash_color_title"
        android:summary="#FFFFFF"
        android:persistent="false" />

    <com.matrixx.settings.preferences.SecureSettingSeekBarPreference
        android:key="cutout_progress_opacity"
        android:title="@string/cutout_progress_opacity_title"
        android:max="100"
        settings:min="0"
        settings:interval="1"
        settings:units="%"
        android:defaultValue="90" />

    <com.matrixx.settings.preferences.SecureSettingSeekBarPreference
        android:key="cutout_progress_stroke_width_dp10"
        android:title="@string/cutout_progress_stroke_width_title"
        android:max="80"
        settings:min="5"
        settings:interval="5"
        settings:units=" (×0.1 dp)"
        android:defaultValue="20" />

    <com.matrixx.settings.preferences.SecureSettingSeekBarPreference
        android:key="cutout_progress_ring_gap_x1000"
        android:title="@string/cutout_progress_ring_gap_title"
        android:max="2000"
        settings:min="1000"
        settings:interval="10"
        settings:units=" (×0.001)"
        android:defaultValue="1155" />

    <PreferenceCategory
        android:key="cutout_progress_cat_battery"
        android:title="@string/cutout_progress_cat_battery"
        android:dependency="cutout_progress_enabled">

        <com.matrixx.settings.preferences.SecureSettingSwitchPreference
            android:key="cutout_progress_battery_indicator_enabled"
            android:title="@string/cutout_progress_battery_indicator_title"
            android:summary="@string/cutout_progress_battery_indicator_summary"
            android:defaultValue="false" />

        <com.matrixx.settings.preferences.SecureSettingSwitchPreference
            android:key="cutout_progress_charging_ring_enabled"
            android:title="@string/cutout_progress_charging_ring_title"
            android:summary="@string/cutout_progress_charging_ring_summary"
            android:defaultValue="true" />

        <com.matrixx.settings.preferences.SecureSettingSwitchPreference
            android:key="cutout_progress_charging_pulse_enabled"
            android:title="@string/cutout_progress_charging_pulse_title"
            android:summary="@string/cutout_progress_charging_pulse_summary"
            android:defaultValue="true"
            android:dependency="cutout_progress_charging_ring_enabled" />

    </PreferenceCategory>

    <PreferenceCategory
        android:key="cutout_progress_cat_music"
        android:title="@string/cutout_progress_cat_music"
        android:dependency="cutout_progress_enabled">

        <com.matrixx.settings.preferences.SecureSettingSwitchPreference
            android:key="cutout_progress_music_enabled"
            android:title="@string/cutout_progress_music_title"
            android:summary="@string/cutout_progress_music_summary"
            android:defaultValue="false" />

        <com.matrixx.settings.preferences.SecureSettingListPreference
            android:key="cutout_progress_music_color_mode"
            android:title="@string/cutout_progress_music_color_mode_title"
            android:summary="%s"
            android:entries="@array/cutout_progress_music_color_mode_entries"
            android:entryValues="@array/cutout_progress_music_color_mode_values"
            android:defaultValue="0"
            android:dependency="cutout_progress_music_enabled" />

        <Preference
            android:key="cutout_progress_music_custom_color"
            android:title="@string/cutout_progress_music_custom_color_title"
            android:summary="#9C27B0"
            android:persistent="false"
            android:dependency="cutout_progress_music_enabled" />

        <com.matrixx.settings.preferences.SecureSettingSeekBarPreference
            android:key="cutout_progress_music_opacity"
            android:title="@string/cutout_progress_music_opacity_title"
            android:max="100"
            settings:min="0"
            settings:interval="1"
            settings:units="%"
            android:defaultValue="85"
            android:dependency="cutout_progress_music_enabled" />

        <com.matrixx.settings.preferences.SecureSettingSeekBarPreference
            android:key="cutout_progress_music_stroke_dp10"
            android:title="@string/cutout_progress_music_stroke_title"
            android:max="80"
            settings:min="5"
            settings:interval="5"
            settings:units=" (×0.1 dp)"
            android:defaultValue="20"
            android:dependency="cutout_progress_music_enabled" />

        <com.matrixx.settings.preferences.SecureSettingSwitchPreference
            android:key="cutout_progress_music_clockwise"
            android:title="@string/cutout_progress_music_clockwise_title"
            android:defaultValue="true"
            android:dependency="cutout_progress_music_enabled" />

    </PreferenceCategory>

    <PreferenceCategory
        android:key="cutout_progress_cat_behaviour"
        android:title="@string/cutout_progress_cat_behaviour"
        android:dependency="cutout_progress_enabled">

        <com.matrixx.settings.preferences.SecureSettingSwitchPreference
            android:key="cutout_progress_clockwise"
            android:title="@string/cutout_progress_clockwise_title"
            android:summary="@string/cutout_progress_clockwise_summary"
            android:defaultValue="true" />

        <com.matrixx.settings.preferences.SecureSettingSwitchPreference
            android:key="cutout_progress_min_vis_enabled"
            android:title="@string/cutout_progress_min_vis_title"
            android:summary="@string/cutout_progress_min_vis_summary"
            android:defaultValue="true" />

        <com.matrixx.settings.preferences.SecureSettingSeekBarPreference
            android:key="cutout_progress_min_vis_ms"
            android:title="@string/cutout_progress_min_vis_ms_title"
            android:max="3000"
            settings:min="100"
            settings:interval="100"
            settings:units="ms"
            android:defaultValue="500"
            android:dependency="cutout_progress_min_vis_enabled" />

        <com.matrixx.settings.preferences.SecureSettingListPreference
            android:key="cutout_progress_easing"
            android:title="@string/cutout_progress_easing_title"
            android:summary="%s"
            android:entries="@array/cutout_progress_easing_entries"
            android:entryValues="@array/cutout_progress_easing_values"
            android:defaultValue="0" />

    </PreferenceCategory>

    <PreferenceCategory
        android:key="cutout_progress_cat_bg_ring"
        android:title="@string/cutout_progress_cat_bg_ring"
        android:dependency="cutout_progress_enabled">

        <com.matrixx.settings.preferences.SecureSettingSwitchPreference
            android:key="cutout_progress_bg_ring_enabled"
            android:title="@string/cutout_progress_bg_ring_enabled_title"
            android:summary="@string/cutout_progress_bg_ring_enabled_summary"
            android:defaultValue="true" />

        <Preference
            android:key="cutout_progress_bg_ring_color"
            android:title="@string/cutout_progress_bg_ring_color_title"
            android:summary="#808080"
            android:persistent="false"
            android:dependency="cutout_progress_bg_ring_enabled" />

        <com.matrixx.settings.preferences.SecureSettingSeekBarPreference
            android:key="cutout_progress_bg_ring_opacity"
            android:title="@string/cutout_progress_bg_ring_opacity_title"
            android:max="100"
            settings:min="0"
            settings:interval="1"
            settings:units="%"
            android:defaultValue="30"
            android:dependency="cutout_progress_bg_ring_enabled" />

    </PreferenceCategory>

    <PreferenceCategory
        android:key="cutout_progress_cat_finish"
        android:title="@string/cutout_progress_cat_finish"
        android:dependency="cutout_progress_enabled">

        <com.matrixx.settings.preferences.SecureSettingListPreference
            android:key="cutout_progress_finish_style"
            android:title="@string/cutout_progress_finish_style_title"
            android:summary="%s"
            android:entries="@array/cutout_progress_finish_style_entries"
            android:entryValues="@array/cutout_progress_finish_style_values"
            android:defaultValue="0" />

        <com.matrixx.settings.preferences.SecureSettingSeekBarPreference
            android:key="cutout_progress_finish_hold_ms"
            android:title="@string/cutout_progress_finish_hold_title"
            android:max="2000"
            settings:min="0"
            settings:interval="50"
            settings:units="ms"
            android:defaultValue="500" />

        <com.matrixx.settings.preferences.SecureSettingSeekBarPreference
            android:key="cutout_progress_finish_exit_ms"
            android:title="@string/cutout_progress_finish_exit_title"
            android:max="2000"
            settings:min="0"
            settings:interval="50"
            settings:units="ms"
            android:defaultValue="500" />

        <com.matrixx.settings.preferences.SecureSettingSwitchPreference
            android:key="cutout_progress_finish_use_flash"
            android:title="@string/cutout_progress_finish_flash_title"
            android:summary="@string/cutout_progress_finish_flash_summary"
            android:defaultValue="true" />

        <com.matrixx.settings.preferences.SecureSettingSwitchPreference
            android:key="cutout_progress_completion_pulse"
            android:title="@string/cutout_progress_pulse_title"
            android:summary="@string/cutout_progress_pulse_summary"
            android:defaultValue="true" />

    </PreferenceCategory>

    <PreferenceCategory
        android:key="cutout_progress_cat_geometry"
        android:title="@string/cutout_progress_cat_geometry"
        android:dependency="cutout_progress_enabled">

        <com.matrixx.settings.preferences.SecureSettingSwitchPreference
            android:key="cutout_progress_path_mode"
            android:title="@string/cutout_progress_path_mode_title"
            android:summary="@string/cutout_progress_path_mode_summary"
            android:defaultValue="false" />

        <com.matrixx.settings.preferences.SecureSettingSeekBarPreference
            android:key="cutout_progress_ring_scale_x_x1000"
            android:title="@string/cutout_progress_scale_x_title"
            android:max="3000"
            settings:min="500"
            settings:interval="50"
            settings:units=" (×0.001)"
            android:defaultValue="1000" />

        <com.matrixx.settings.preferences.SecureSettingSeekBarPreference
            android:key="cutout_progress_ring_scale_y_x1000"
            android:title="@string/cutout_progress_scale_y_title"
            android:max="3000"
            settings:min="500"
            settings:interval="50"
            settings:units=" (×0.001)"
            android:defaultValue="1000" />

        <com.matrixx.settings.preferences.SecureSettingSeekBarPreference
            android:key="cutout_progress_ring_offset_x_dp10"
            android:title="@string/cutout_progress_offset_x_title"
            android:max="200"
            settings:min="-200"
            settings:interval="5"
            settings:units=" (×0.1 dp)"
            android:defaultValue="0" />

        <com.matrixx.settings.preferences.SecureSettingSeekBarPreference
            android:key="cutout_progress_ring_offset_y_dp10"
            android:title="@string/cutout_progress_offset_y_title"
            android:max="200"
            settings:min="-200"
            settings:interval="5"
            settings:units=" (×0.1 dp)"
            android:defaultValue="0" />

    </PreferenceCategory>

    <PreferenceCategory
        android:key="cutout_progress_cat_labels"
        android:title="@string/cutout_progress_cat_labels"
        android:dependency="cutout_progress_enabled">

        <com.matrixx.settings.preferences.SecureSettingSwitchPreference
            android:key="cutout_progress_percent_enabled"
            android:title="@string/cutout_progress_percent_enabled_title"
            android:summary="@string/cutout_progress_percent_enabled_summary"
            android:defaultValue="false" />

        <com.matrixx.settings.preferences.SecureSettingSeekBarPreference
            android:key="cutout_progress_percent_size_sp10"
            android:title="@string/cutout_progress_percent_size_title"
            android:max="200"
            settings:min="60"
            settings:interval="5"
            settings:units=" (×0.1 sp)"
            android:defaultValue="80"
            android:dependency="cutout_progress_percent_enabled" />

        <com.matrixx.settings.preferences.SecureSettingSwitchPreference
            android:key="cutout_progress_percent_bold"
            android:title="@string/cutout_progress_percent_bold_title"
            android:defaultValue="true"
            android:dependency="cutout_progress_percent_enabled" />

        <com.matrixx.settings.preferences.SecureSettingListPreference
            android:key="cutout_progress_percent_position"
            android:title="@string/cutout_progress_percent_position_title"
            android:summary="%s"
            android:entries="@array/cutout_progress_position_entries"
            android:entryValues="@array/cutout_progress_position_values"
            android:defaultValue="0"
            android:dependency="cutout_progress_percent_enabled" />

        <com.matrixx.settings.preferences.SecureSettingSwitchPreference
            android:key="cutout_progress_filename_enabled"
            android:title="@string/cutout_progress_filename_enabled_title"
            android:summary="@string/cutout_progress_filename_enabled_summary"
            android:defaultValue="false" />

        <com.matrixx.settings.preferences.SecureSettingSeekBarPreference
            android:key="cutout_progress_filename_size_sp10"
            android:title="@string/cutout_progress_filename_size_title"
            android:max="180"
            settings:min="50"
            settings:interval="5"
            settings:units=" (×0.1 sp)"
            android:defaultValue="70"
            android:dependency="cutout_progress_filename_enabled" />

        <com.matrixx.settings.preferences.SecureSettingSwitchPreference
            android:key="cutout_progress_filename_bold"
            android:title="@string/cutout_progress_filename_bold_title"
            android:defaultValue="false"
            android:dependency="cutout_progress_filename_enabled" />

        <com.matrixx.settings.preferences.SecureSettingListPreference
            android:key="cutout_progress_filename_position"
            android:title="@string/cutout_progress_filename_position_title"
            android:summary="%s"
            android:entries="@array/cutout_progress_position_entries"
            android:entryValues="@array/cutout_progress_position_values"
            android:defaultValue="4"
            android:dependency="cutout_progress_filename_enabled" />

        <com.matrixx.settings.preferences.SecureSettingSeekBarPreference
            android:key="cutout_progress_filename_max_chars"
            android:title="@string/cutout_progress_filename_max_chars_title"
            android:max="60"
            settings:min="5"
            settings:interval="1"
            android:defaultValue="20"
            android:dependency="cutout_progress_filename_enabled" />

        <com.matrixx.settings.preferences.SecureSettingListPreference
            android:key="cutout_progress_filename_truncate"
            android:title="@string/cutout_progress_filename_truncate_title"
            android:summary="%s"
            android:entries="@array/cutout_progress_truncate_entries"
            android:entryValues="@array/cutout_progress_truncate_values"
            android:defaultValue="0"
            android:dependency="cutout_progress_filename_enabled" />

    </PreferenceCategory>

    <PreferenceCategory
        android:key="cutout_progress_cat_badge"
        android:title="@string/cutout_progress_cat_badge"
        android:dependency="cutout_progress_enabled">

        <com.matrixx.settings.preferences.SecureSettingSwitchPreference
            android:key="cutout_progress_show_count_badge"
            android:title="@string/cutout_progress_badge_title"
            android:summary="@string/cutout_progress_badge_summary"
            android:defaultValue="false" />

        <com.matrixx.settings.preferences.SecureSettingSeekBarPreference
            android:key="cutout_progress_badge_text_size_sp10"
            android:title="@string/cutout_progress_badge_size_title"
            android:max="180"
            settings:min="60"
            settings:interval="5"
            settings:units=" (×0.1 sp)"
            android:defaultValue="100"
            android:dependency="cutout_progress_show_count_badge" />

        <com.matrixx.settings.preferences.SecureSettingSeekBarPreference
            android:key="cutout_progress_badge_offset_x_dp10"
            android:title="@string/cutout_progress_badge_offset_x_title"
            android:max="100"
            settings:min="-100"
            settings:interval="5"
            settings:units=" (×0.1 dp)"
            android:defaultValue="0"
            android:dependency="cutout_progress_show_count_badge" />

        <com.matrixx.settings.preferences.SecureSettingSeekBarPreference
            android:key="cutout_progress_badge_offset_y_dp10"
            android:title="@string/cutout_progress_badge_offset_y_title"
            android:max="100"
            settings:min="-100"
            settings:interval="5"
            settings:units=" (×0.1 dp)"
            android:defaultValue="0"
            android:dependency="cutout_progress_show_count_badge" />

    </PreferenceCategory>

</PreferenceScreen>
