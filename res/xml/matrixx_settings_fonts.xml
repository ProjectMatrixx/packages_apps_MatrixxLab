<PreferenceScreen
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:settings="http://schemas.android.com/apk/res-auto"
    android:title="@string/font_settings_title">

    <com.matrixx.settings.preferences.SystemSettingListPreference
        android:key="font_mode"
        android:title="@string/font_mode_title"
        android:summary="%s"
        android:entries="@array/font_mode_entries"
        android:entryValues="@array/font_mode_values"
        android:defaultValue="prebuilt" />

    <!-- Prebuilt Fonts -->
    <com.matrixx.settings.preferences.FontsPickerPreference
        android:key="system_font"
        android:title="@string/theme_customization_font_title"
        android:summary="@string/theme_customization_font_summary" />

    <!-- Custom Font Picker -->
    <Preference
        android:key="custom_font_picker"
        android:title="@string/custom_font_picker_title"
        android:summary="@string/custom_font_picker_summary" />

    <!-- GitHub Font Picker -->
    <Preference
        android:key="github_font_picker"
        android:title="@string/github_font_picker_title"
        android:summary="@string/github_font_picker_summary" />

    <!-- Custom Font Info -->
    <Preference
        android:key="custom_font_info"
        android:title="@string/custom_font_installed_title"
        android:selectable="false" />

    <!-- Reset Custom Font Button -->
    <Preference
        android:key="reset_custom_font"
        android:title="@string/reset_custom_font_title"
        android:summary="@string/reset_custom_font_summary" />

    <!-- Reboot Button for Custom Font -->
    <Preference
        android:key="reboot_for_font"
        android:title="@string/reboot_device"
        android:summary="@string/reboot_required_custom_font_desc" />

</PreferenceScreen>
