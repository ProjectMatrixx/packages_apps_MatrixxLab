<PreferenceScreen
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:settings="http://schemas.android.com/apk/res/com.android.settings"
    xmlns:lineage="http://schemas.android.com/apk/res-auto">

    <com.android.settingslib.widget.LayoutPreference
        android:key="clock_preview"
        android:layout="@layout/lockscreen_clock_preview"
        android:selectable="false"
        settings:allowDividerBelow="true"
        settings:isPreferenceVisible="true" />
 
    <com.matrixx.settings.preferences.LockClockFontsPreference
        android:key="lock_clock_font"
        android:title="@string/theme_customization_lock_clock_title"
        android:summary="theme_customization_lock_clock_summary" />

    <com.matrixx.settings.preferences.SecureSettingListPreference
        android:key="lock_screen_custom_clock_color_mode"
        android:title="@string/lockscreen_custom_clock_color_mode_title"
        android:entries="@array/lockscreen_custom_clock_color_mode_entries"
        android:entryValues="@array/lockscreen_custom_clock_color_mode_values"
        android:summary="%s"
        android:defaultValue="default" />

    <com.matrixx.settings.preferences.SecureSettingSeekBarPreference
        android:key="lock_screen_custom_clock_size_scale"
        android:title="@string/clock_size_title"
        android:summary="@string/clock_size_summary"
        android:defaultValue="100"
        android:max="150"
        settings:min="50"
        settings:units="%" />

    <com.matrixx.settings.preferences.colorpicker.SecureSettingColorPickerPreference
        android:key="lock_screen_custom_clock_custom_color"
        android:title="@string/custom_color"
        android:defaultValue="0xFFFFFFFF" />

    <com.matrixx.settings.preferences.SecureSettingSeekBarPreference
        android:key="lock_screen_custom_clock_opacity"
        android:title="@string/lockscreen_custom_clock_opacity_title"
        android:summary="@string/lockscreen_custom_clock_opacity_summary"
        android:defaultValue="100"
	    android:max="100"
        settings:min="10" 
        settings:units="%" />

    <com.matrixx.settings.preferences.SecureSettingSeekBarPreference
        android:key="lock_screen_custom_clock_margin_top"
        android:title="@string/lockscreen_custom_clock_frame_margin_top_title"
        android:summary="@string/lockscreen_custom_clock_frame_margin_top_summary"
        android:defaultValue="15"
	    android:max="100"
        settings:min="0" 
        settings:units="@string/unit_pixels" />

    <com.android.settingslib.widget.FooterPreference
        android:key="custom_clock_style_info"
        android:title="@string/lockscreen_custom_clock_style_info"
        android:selectable="false"
        settings:searchable="false" />

</PreferenceScreen>
