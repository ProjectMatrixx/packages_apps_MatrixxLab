<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center|top"
    android:gravity="center|top"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="155dp"
        android:layout_height="100dp"
        android:layout_gravity="center"
        android:background="@drawable/lockscreen_clock_29_bg"
        tools:ignore="UselessParent">

        <ImageView
            android:id="@+id/user_profile_icon"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_gravity="end"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="20dp"
            android:scaleType="centerCrop"
            android:importantForAccessibility="no"
            android:src="@drawable/lockscreen_clock_27_logo"
            android:tag="profile_picture" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start|center"
            android:layout_marginStart="14dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="11dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="1dp"
                android:includeFontPadding="false"
                android:tag="accent1|nolineheight|username"
                android:text="Username"
                android:fontFamily="@*android:string/config_clockFontFamily"
                android:textColor="@android:color/system_accent1_300"
                android:textSize="11sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:layout_marginBottom="1dp"
                android:tag="text1"
                android:text="Now It's"
                android:textColor="#FFFFFF"
                android:textSize="8sp" />

            <TextClock
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:format12Hour="hh • mm a"
                android:format24Hour="kk • mm a"
                android:includeFontPadding="false"
                android:layout_marginBottom="1dp"
                android:tag="accent1"
                android:fontFamily="@*android:string/config_clockFontFamily"
                android:textColor="@android:color/system_accent1_200"
                android:textSize="7sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:layout_marginBottom="1dp"
                android:tag="text1"
                android:text="Today is"
                android:textColor="#FFFFFF"
                android:textSize="8sp" />

            <TextClock
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:format12Hour="EEEE dd MMMM"
                android:format24Hour="EEEE dd MMMM"
                android:includeFontPadding="false"
                android:layout_marginBottom="1dp"
                android:tag="accent1"
                android:fontFamily="@*android:string/config_clockFontFamily"
                android:textColor="@android:color/system_accent1_200"
                android:textSize="7sp" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
