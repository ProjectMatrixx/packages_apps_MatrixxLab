<PreferenceScreen
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:settings="http://schemas.android.com/apk/res/com.android.settings"
    android:title="@string/spoofing_title">

    <PreferenceCategory
        android:key="spoofing_system_wide_category"
        android:title="@string/spoofing_system_wide_category">

        <!-- Pixel props -->
        <com.matrixx.settings.preferences.SecureSettingSwitchPreference
            android:key="pi_pp_spoof"
            android:title="@string/spoofing_pixel_props_title"
            android:summary="@string/spoofing_pixel_props_summary"
            android:defaultValue="true" />

        <!-- Tensor features -->
        <com.matrixx.settings.preferences.SecureSettingSwitchPreference
            android:key="pi_tensor_spoof"
            android:title="@string/tensor_spoof_title"
            android:summary="@string/tensor_spoof_summary"
            android:defaultValue="false" />
    </PreferenceCategory>

    <PreferenceCategory
        android:key="spoofing_app_specific_category"
        android:title="@string/spoofing_app_specific_category">

        <!-- App Spoofing -->
        <Preference
            android:key="user_selectable_app_spoofing"
            android:title="@string/user_selectable_app_spoofing_title"
            android:summary="@string/user_selectable_app_spoofing_summary"
            android:fragment="com.matrixx.settings.fragments.misc.UserSelectedAppSpoofSettings" />

        <!-- Google Photos -->
        <com.matrixx.settings.preferences.SecureSettingSwitchPreference
            android:key="pi_photos_spoof"
            android:title="@string/spoofing_photos_title"
            android:summary="@string/spoofing_photos_summary"
            android:defaultValue="true" />

        <!-- Snapchat -->
        <com.matrixx.settings.preferences.SecureSettingSwitchPreference
            android:key="pi_snapchat_spoof"
            android:title="@string/spoofing_snap_title"
            android:summary="@string/spoofing_snap_summary"
            android:defaultValue="false" />
    </PreferenceCategory>
</PreferenceScreen>
