<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/clock_frame"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center_horizontal|top"
    android:gravity="center_horizontal|top">

    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/clock_bubble_3"
            android:layout_marginTop="30dp"
            android:layout_marginStart="25dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/clock_bubble_1"
            android:gravity="center">

            <TextClock
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/general_sans"
                android:format12Hour="hh"
                android:textColor="@android:color/system_accent1_900"
                android:format24Hour="HH"
                android:textSize="56sp"
                android:textStyle="bold" />

            <TextClock
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:format12Hour="mm"
                android:format24Hour="MM"
                android:fontFamily="@font/general_sans"
                android:textSize="24sp"
                android:textColor="@android:color/system_accent1_900"
                android:textStyle="bold"
                android:layout_marginStart="3dp"
                android:layout_marginTop="12dp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="70dp"
            android:layout_marginTop="135dp"
            android:gravity="center"
            android:background="@drawable/clock_bubble_2"
            android:tag="accent2">

            <TextClock
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/general_sans"
                android:format12Hour="dd MMM"
                android:gravity="center"
                android:textAllCaps="true"
                android:textColor="@android:color/system_accent2_900"
                android:textSize="8sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="135dp"
            android:layout_marginTop="61dp"
            android:background="@drawable/clock_bubble_2"
            android:gravity="center">

            <TextClock
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/general_sans"
                android:format12Hour="ss"
                android:gravity="center"
                android:textAllCaps="true"
                android:textColor="@android:color/system_accent2_50"
                android:textSize="10sp" />

        </LinearLayout>
    </FrameLayout>
</LinearLayout>
