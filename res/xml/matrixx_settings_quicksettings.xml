<PreferenceScreen
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:settings="http://schemas.android.com/apk/res/com.android.settings"
    xmlns:lineage="http://schemas.android.com/apk/res-auto"
    android:title="@string/qs_panel_options_title">

    <PreferenceCategory
        android:key="quick_settings_interface_category"
        android:title="@string/quick_settings_interface_category">

        <Preference
            android:key="qs_header_image"
            android:title="@string/qs_header_image_title"
            android:summary="@string/qs_header_image_summary"
            android:fragment="com.matrixx.settings.fragments.quicksettings.QsHeaderImageSettings" />

        <!-- Data usage -->
        <com.matrixx.settings.preferences.SystemSettingSwitchPreference
            android:key="qs_show_data_usage"
            android:title="@string/quick_settings_data_usage_title"
            android:summary="@string/quick_settings_data_usage_summary"
            android:defaultValue="false" />

        <com.matrixx.settings.preferences.SystemSettingSwitchPreference
            android:key="qs_tile_haptic"
            android:title="@string/qs_brightness_slider_haptic_title"
            android:summary="@string/quick_settings_tile_haptic_summary"
            android:defaultValue="false" />

    </PreferenceCategory>

    <PreferenceCategory
         android:title="@string/qs_brightness_slider_category">

        <com.matrixx.settings.preferences.SystemSettingSwitchPreference
            android:key="qs_brightness_slider_haptic"
            android:title="@string/qs_brightness_slider_haptic_title"
            android:summary="@string/qs_brightness_slider_haptic_summary"/>

        <!-- Brightness Slider Style -->
        <com.matrixx.settings.preferences.SystemSettingListPreference
            android:key="qs_brightness_slider_shape"
            android:title="@string/qs_brightness_slider_shape_title"
            android:entries="@array/qs_brightness_slider_shape_entries"
            android:entryValues="@array/qs_brightness_slider_shape_values"
            android:defaultValue="0" />

    </PreferenceCategory>

    <PreferenceCategory
        android:key="qs_layout_category"
        android:title="@string/quick_settings_layout_category_title">

        <com.matrixx.settings.preferences.SystemSettingListPreference
            android:key="qs_tile_shape"
            android:title="@string/quick_settings_tile_shape_title"
            android:entries="@array/quick_settings_tile_shape_entries"
            android:entryValues="@array/quick_settings_tile_shape_values"
            android:defaultValue="0" />

        <Preference
            android:key="qs_layout_columns_rows"
            android:title="@string/qs_layout_columns_rows_title"
            android:summary="@string/qs_layout_columns_rows_summary"
            android:fragment="com.matrixx.settings.fragments.quicksettings.LayoutSettings" />
    </PreferenceCategory>
</PreferenceScreen>
