<PreferenceScreen
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:lineage="http://schemas.android.com/apk/res-auto"
    xmlns:settings="http://schemas.android.com/apk/res/com.android.settings"
    android:title="@string/sound_options_title">

    <!-- Screenshot Sound  -->
    <com.matrixx.settings.preferences.SystemSettingSwitchPreference
        android:key="screenshot_shutter_sound"
        android:title="@string/screenshot_shutter_sound_title"
        android:summary="@string/screenshot_shutter_sound_summary"
        android:defaultValue="true" />

    <!-- Volume panel -->
    <PreferenceCategory
        android:key="volume_panel"
        android:title="@string/volume_panel_category" >

        <com.matrixx.settings.preferences.SecureSettingSeekBarPreference
            android:key="volume_dialog_dismiss_timeout"
            android:title="@string/volume_dialog_timeout_title"
            android:defaultValue="3000"
            android:max="10000"
            settings:min="1000"
            settings:interval="500"
            settings:units="@string/unit_milliseconds" />

        <com.matrixx.settings.preferences.SecureSettingSwitchPreference
            android:key="volume_dialog_haptic_feedback"
            android:title="@string/volume_dialog_haptic_feedback_title"
            android:defaultValue="true" />
    </PreferenceCategory>

    <!-- Edge scrolling intensity -->
    <PreferenceCategory
        android:key="haptics_settings_category"
        android:title="@string/haptics_settings_category" >

        <Preference
            android:key="haptics_settings"
            android:title="@string/haptics_settings_title"
            android:summary="@string/haptics_settings_summary"
            android:fragment="com.matrixx.settings.fragments.sound.HapticsPreferenceFragment"/>
    </PreferenceCategory>

    <!-- In-call feedback -->
    <PreferenceCategory
        android:key="incall_vib_options"
        android:title="@string/incall_vibration_category" >

        <com.matrixx.settings.preferences.SystemSettingSwitchPreference
            android:key="vibrate_on_connect"
            android:title="@string/incall_vibrate_connect_title"
            android:defaultValue="false" />

        <com.matrixx.settings.preferences.SystemSettingSwitchPreference
            android:key="vibrate_on_callwaiting"
            android:title="@string/incall_vibrate_call_wait_title"
            android:defaultValue="false" />

        <com.matrixx.settings.preferences.SystemSettingSwitchPreference
            android:key="vibrate_on_disconnect"
            android:title="@string/incall_vibrate_disconnect_title"
            android:defaultValue="false" />
    </PreferenceCategory>
</PreferenceScreen>
