<PreferenceScreen
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:settings="http://schemas.android.com/apk/res/com.android.settings"
    android:title="@string/misc_options_title">

    <PreferenceCategory
        android:key="miscellaneous_spoofing_category"
        android:title="@string/miscellaneous_spoofing_category">

        <!-- Component spoofing -->
        <Preference
            android:key="spoofing"
            android:title="@string/spoofing_title"
            android:summary="@string/spoofing_summary"
            android:fragment="com.matrixx.settings.fragments.misc.Spoofing" />

        <!-- Application downgrade -->
        <com.matrixx.settings.preferences.GlobalSettingSwitchPreference
            android:key="pm_downgrade_allowed"
            android:title="@string/app_downgrade_title"
            android:summary="@string/app_downgrade_summary"
            android:defaultValue="false"/>

        <Preference
            android:key="hide_developer_status_settings"
            android:title="@string/hide_developer_status_title"
            android:summary="@string/hide_developer_status_summary"
            android:fragment="com.android.settings.security.HideDeveloperStatusSettings"
            settings:controller="com.android.settings.security.HideDeveloperStatusPreferenceController" />

        <!-- Ignore window secure flags -->
        <com.matrixx.settings.preferences.GlobalSettingSwitchPreference
            android:key="window_ignore_secure"
            android:title="@string/miscellaneous_ignore_window_secure_title"
            android:summary="@string/miscellaneous_ignore_window_secure_summary"
            android:defaultValue="false" />

        <!-- Hide screen capture status -->
        <com.matrixx.settings.preferences.SystemSettingSwitchPreference
            android:key="hide_screen_capture_status"
            android:title="@string/hide_screen_capture_status_title"
            android:summary="@string/hide_screen_capture_status_summary"
            android:defaultValue="false"/>

        <!-- Disable flash sms -->
        <com.matrixx.settings.preferences.SystemSettingSwitchPreference
            android:key="disable_flash_sms"
            android:title="@string/disable_flash_sms_title"
            android:summary="@string/disable_flash_sms_summary"
            android:defaultValue="false"/>

        <!-- No storage access framework restrictions -->
        <com.matrixx.settings.preferences.GlobalSettingSwitchPreference
            android:key="no_storage_restrict"
            android:title="@string/no_storage_restrict_title"
            android:summary="@string/no_storage_restrict_summary"
            android:defaultValue="false"/>

        <!-- Unlimit screenrecord -->
        <com.matrixx.settings.preferences.SystemSettingSwitchPreference
            android:key="unlimit_screenrecord"
            android:title="@string/miscellaneous_unlimit_screenrecord_title"
            android:summary="@string/miscellaneous_unlimit_screenrecord_summary"
            android:defaultValue="false" />

        <!-- Hide applist -->
        <Preference
            android:key="hide_applist_setting"
            android:title="@string/hide_applist_title"
            android:summary="@string/hide_applist_summary"
            android:fragment="com.matrixx.settings.fragments.misc.HideAppListSettings" />

        <!-- Block PairIP license activity -->
        <com.matrixx.settings.preferences.SystemPropertySwitchPreference
            android:key="persist.sys.pairip.activity.block"
            android:title="@string/miscellaneous_pairip_activity_block_title"
            android:summary="@string/miscellaneous_pairip_activity_block_summary"
            android:defaultValue="false" />

     </PreferenceCategory>

    <PreferenceCategory
        android:title="@string/extras_category_title">

        <!-- Gaming mode -->
        <Preference
            android:key="gaming_mode"
            android:title="@string/gaming_mode_title"
            android:summary="@string/gaming_mode_summary">

            <intent
                android:action="android.intent.action.MAIN"
                android:targetPackage="io.chaldeaprjkt.gamespace"
                android:targetClass="io.chaldeaprjkt.gamespace.settings.SettingsActivity" />
        </Preference>

        <!-- Sidebar -->
        <Preference
            android:key="sidebar"
            android:title="@string/sidebar_title"
            android:summary="@string/sidebar_summary">

            <intent
                android:action="android.intent.action.IA_SETTINGS"
                android:targetPackage="com.libremobileos.sidebar"
                android:targetClass="com.libremobileos.sidebar.ui.sidebar.SidebarSettingsActivity" />
        </Preference>

        <!-- Screen Off animation -->
        <com.matrixx.settings.preferences.SystemSettingListPreference
            android:key="screen_off_animation"
            android:title="@string/screen_off_animation_title"
            android:dialogTitle="@string/screen_off_animation_title"
            android:entries="@array/screen_off_animation_entries"
            android:entryValues="@array/screen_off_animation_values"
            android:defaultValue="0" />

        <!-- Three fingers swipe action -->
        <ListPreference
            android:key="three_fingers_swipe"
            android:dialogTitle="@string/three_fingers_swipe_title"
            android:title="@string/three_fingers_swipe_title"
            android:entries="@array/hardware_keys_action_entries"
            android:entryValues="@array/hardware_keys_action_values"
            android:persistent="false" />

        <Preference
            android:key="gesture_shake_action"
            android:title="@string/shake_gestures_enabled_title"
            android:summary="@string/shake_gestures_enabled_summary"
            android:fragment="com.matrixx.settings.fragments.misc.ShakeGestures" />

        <!-- Pocket Judge -->
        <com.matrixx.settings.preferences.SystemSettingSwitchPreference
            android:key="pocket_judge"
            android:title="@string/pocket_judge_title"
            android:summary="@string/pocket_judge_summary"
            android:defaultValue="false" />

        <!-- Rotation button -->
        <com.matrixx.settings.preferences.SystemSettingSwitchPreference
            android:key="enable_rotation_button"
            android:title="@string/floating_rotation_button_title"
            android:summary="@string/floating_rotation_button_summary"
            android:defaultValue="true" />

        <!-- Smart Pixels -->
        <Preference
            android:key="smart_pixels"
            android:title="@string/smart_pixels_title"
            android:summary="@string/smart_pixels_summary"
            android:fragment="com.matrixx.settings.fragments.misc.SmartPixels" />

        <!-- Sensor block per package -->
        <Preference
            android:key="sensor_block_settings"
            android:title="@string/sensor_block_title"
            android:summary="@string/sensor_block_summary"
            android:fragment="com.matrixx.settings.fragments.misc.SensorBlock"/>
     </PreferenceCategory>
</PreferenceScreen>
